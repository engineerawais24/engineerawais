# CareerPilot backend configuration (copy to .env — NEVER commit .env).
# No secrets are required for the Sprint 16 local single-user MVP.

APP_NAME=CareerPilot Backend
API_VERSION=0.1.0
ENVIRONMENT=development

# SQLite for the local MVP. Swap for PostgreSQL later WITHOUT code changes, e.g.:
#   DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/careerpilot
DATABASE_URL=sqlite:///./careerpilot.db
STORAGE_PROVIDER=sqlite

# CORS — ONLY the local CareerPilot frontend origins. "null" covers opening
# app/index.html directly from disk (file:// → Origin: null).
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000,null

# Local development single-user (no auth in this sprint).
DEV_USER_EMAIL=dev@careerpilot.local
DEV_USER_NAME=CareerPilot Developer
